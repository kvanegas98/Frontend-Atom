# ============================================================
#  Angular / Node.js — .gitignore profesional
# ============================================================

# ----------------------------------------------------------
# Dependencias
# ----------------------------------------------------------
node_modules/
.npm/
.pnpm-store/
.yarn/

# ----------------------------------------------------------
# Build outputs
# ----------------------------------------------------------
dist/
build/
out/
out-tsc/
.angular/cache/

# ----------------------------------------------------------
# Variables de entorno y secretos 
# ----------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.secret
secrets/
credentials/

# ----------------------------------------------------------
# Archivos de sistema operativo
# ----------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ----------------------------------------------------------
# IDEs y editores
# ----------------------------------------------------------
# VSCode — solo ignorar configs personales, no las compartidas del equipo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.vscode/settings.local.json

# IntelliJ / WebStorm
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs
*.swp
*.swo
.~lock.*

# ----------------------------------------------------------
# Testing y cobertura
# ----------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/

# ----------------------------------------------------------
# Logs
# ----------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ----------------------------------------------------------
# Herramientas de CI / análisis
# ----------------------------------------------------------
.eslintcache
.stylelintcache
.cache/

# ----------------------------------------------------------
# Archivos temporales
# ----------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
.temp/
